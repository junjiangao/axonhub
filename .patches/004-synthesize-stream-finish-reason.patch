+// ensureStreamFinishReason synthesizes finish_reason for stream chunks when the
+// upstream provider omits it.
+//
+// Two cases:
+//  1. A chunk with delta.tool_calls but no finish_reason → set "tool_calls"
+//  2. A terminal usage-only chunk (empty choices + usage) with no finish_reason
+//     in any choice → inject a synthetic choice with "stop".
+//
+// Case 2 follows the OpenAI SSE pattern where the final chunk carries both
+// finish_reason and usage metadata in a single event.
+func ensureStreamFinishReason(resp *llm.Response) {
+	hasFinishReason := false
+
+	for i := range resp.Choices {
+		c := &resp.Choices[i]
+		if c.FinishReason != nil {
+			hasFinishReason = true
+			continue
+		}
+		if c.Delta == nil || len(c.Delta.ToolCalls) == 0 {
+			continue
+		}
+		c.FinishReason = lo.ToPtr("tool_calls")
+		hasFinishReason = true
+	}
+
+	// Terminal usage-only chunk: inject a synthetic choice with "stop"
+	// so the client sees a finish_reason before [DONE].
+	if !hasFinishReason && len(resp.Choices) == 0 && resp.Usage != nil {
+		resp.Choices = append(resp.Choices, llm.Choice{
+			Index:        0,
+			Delta:        &llm.Message{},
+			FinishReason: lo.ToPtr("stop"),
+		})
+	}
+}
