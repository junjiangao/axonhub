+func TestInboundTransformer_TransformStream_SynthesizesFinishReason(t *testing.T) {
+	transformer := NewInboundTransformer()
+
+	t.Run("tool_calls first chunk gets finish_reason, argument chunks do not", func(t *testing.T) {
+		stream, err := transformer.TransformStream(t.Context(), streams.SliceStream([]*llm.Response{
+			{
+				ID:      "chatcmpl-123",
+				Object:  "chat.completion.chunk",
+				Created: 1677652288,
+				Model:   "gpt-4",
+				Choices: []llm.Choice{
+					{
+						Index: 0,
+						Delta: &llm.Message{
+							Role: "assistant",
+							ToolCalls: []llm.ToolCall{
+								{
+									ID:   "call_123",
+									Type: "function",
+									Function: llm.FunctionCall{
+										Name: "get_user_city",
+									},
+									Index: 0,
+								},
+							},
+						},
+					},
+				},
+			},
+			{
+				ID:      "chatcmpl-123",
+				Object:  "chat.completion.chunk",
+				Created: 1677652289,
+				Model:   "gpt-4",
+				Choices: []llm.Choice{
+					{
+						Index: 0,
+						Delta: &llm.Message{
+							Role: "assistant",
+							ToolCalls: []llm.ToolCall{
+								{
+									// No ID: this is an argument-only chunk
+									Function: llm.FunctionCall{
+										Arguments: `{"user_id":"123"}`,
+									},
+									Index: 0,
+								},
+							},
+						},
+					},
+				},
+			},
+			{
+				Object: "[DONE]",
+			},
+		}))
+		require.NoError(t, err)
+
+		var events []*httpclient.StreamEvent
+		for stream.Next() {
+			events = append(events, stream.Current())
+		}
+		require.NoError(t, stream.Err())
+		require.Len(t, events, 3) // 2 data chunks + [DONE]
+
+		// First chunk: tool call with ID should get synthesized finish_reason
+		var first llm.Response
+		require.NoError(t, json.Unmarshal(events[0].Data, &first))
+		require.NotNil(t, first.Choices[0].FinishReason)
+		require.Equal(t, "tool_calls", *first.Choices[0].FinishReason)
+
+		// Second chunk: argument-only, should NOT get finish_reason
+		var second llm.Response
+		require.NoError(t, json.Unmarshal(events[1].Data, &second))
+		require.Nil(t, second.Choices[0].FinishReason)
+
+		// Third chunk: [DONE]
+		require.Equal(t, "[DONE]", string(events[2].Data))
+	})
+
+	t.Run("usage-only chunk after tool calls gets tool_calls as finish_reason", func(t *testing.T) {
+		stream, err := transformer.TransformStream(t.Context(), streams.SliceStream([]*llm.Response{
+			{
+				ID:      "chatcmpl-123",
+				Object:  "chat.completion.chunk",
+				Created: 1677652288,
+				Model:   "gpt-4",
+				Choices: []llm.Choice{
+					{
+						Index: 0,
+						Delta: &llm.Message{
+							Role: "assistant",
+							ToolCalls: []llm.ToolCall{
+								{
+									ID:   "call_123",
+									Type: "function",
+									Function: llm.FunctionCall{
+										Name: "get_user_city",
+									},
+									Index: 0,
+								},
+							},
+						},
+					},
+				},
+			},
+			{
+				ID:      "chatcmpl-123",
+				Object:  "chat.completion.chunk",
+				Created: 1677652289,
+				Model:   "gpt-4",
+				Choices: []llm.Choice{},
+				Usage: &llm.Usage{
+					PromptTokens:     10,
+					CompletionTokens: 20,
+					TotalTokens:      30,
+				},
+			},
+			{
+				Object: "[DONE]",
+			},
+		}))
+		require.NoError(t, err)
+
+		var events []*httpclient.StreamEvent
+		for stream.Next() {
+			events = append(events, stream.Current())
+		}
+		require.NoError(t, stream.Err())
+		require.Len(t, events, 3) // tool call chunk + usage chunk + [DONE]
+
+		// Usage-only chunk (events[1]) should get "tool_calls" because we saw tool calls earlier
+		var usageChunk llm.Response
+		require.NoError(t, json.Unmarshal(events[1].Data, &usageChunk))
+		require.Len(t, usageChunk.Choices, 1)
+		require.NotNil(t, usageChunk.Choices[0].FinishReason)
+		require.Equal(t, "tool_calls", *usageChunk.Choices[0].FinishReason)
+	})
+
+	t.Run("usage-only chunk without prior tool calls gets stop as finish_reason", func(t *testing.T) {
+		stream, err := transformer.TransformStream(t.Context(), streams.SliceStream([]*llm.Response{
+			{
+				ID:      "chatcmpl-123",
+				Object:  "chat.completion.chunk",
+				Created: 1677652288,
+				Model:   "gpt-4",
+				Choices: []llm.Choice{
+					{
+						Index: 0,
+						Delta: &llm.Message{
+							Role: "assistant",
+							Content: llm.MessageContent{
+								Content: lo.ToPtr("Hello"),
+							},
+						},
+					},
+				},
+			},
+			{
+				ID:      "chatcmpl-123",
+				Object:  "chat.completion.chunk",
+				Created: 1677652289,
+				Model:   "gpt-4",
+				Choices: []llm.Choice{},
+				Usage: &llm.Usage{
+					PromptTokens:     10,
+					CompletionTokens: 20,
+					TotalTokens:      30,
+				},
+			},
+			{
+				Object: "[DONE]",
+			},
+		}))
+		require.NoError(t, err)
+
+		var events []*httpclient.StreamEvent
+		for stream.Next() {
+			events = append(events, stream.Current())
+		}
+		require.NoError(t, stream.Err())
+		require.Len(t, events, 3) // text chunk + usage chunk + [DONE]
+
+		// Usage-only chunk (events[1]) without prior tool calls should get "stop"
+		var usageChunk llm.Response
+		require.NoError(t, json.Unmarshal(events[1].Data, &usageChunk))
+		require.Len(t, usageChunk.Choices, 1)
+		require.NotNil(t, usageChunk.Choices[0].FinishReason)
+		require.Equal(t, "stop", *usageChunk.Choices[0].FinishReason)
+	})
+}
 func TestInboundTransformer_TransformStream_SkipsPureReasoningSignatureChunk(t *testing.T) {
