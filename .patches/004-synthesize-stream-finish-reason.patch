+// openAIInboundStream is a stateful stream that synthesizes finish_reason
+// for upstream providers that omit it (e.g. glm-5.1).
+//
+//nolint:containedctx // Checked.
+type openAIInboundStream struct {
+	source streams.Stream[*llm.Response]
+	ctx    context.Context
+	t      *InboundTransformer
+
+	// hasSeenToolCalls tracks whether any prior chunk contained tool calls,
+	// used to infer the correct finish_reason for usage-only terminal chunks.
+	hasSeenToolCalls bool
+
+	current *httpclient.StreamEvent
+	err     error
+}
+
+func (s *openAIInboundStream) Next() bool {
+	for s.source.Next() {
+		chunk := s.source.Current()
+		// Synthesize finish_reason before transforming the chunk.
+		ensureStreamFinishReason(chunk, &s.hasSeenToolCalls)
+		event, err := s.t.TransformStreamChunk(s.ctx, chunk)
+		if err != nil {
+			s.err = err
+			return false
+		}
+		if event == nil {
+			continue
+		}
+		s.current = event
+		return true
+	}
+	return false
+}
+
+func (s *openAIInboundStream) Current() *httpclient.StreamEvent {
+	return s.current
+}
+
+func (s *openAIInboundStream) Err() error {
+	if s.err != nil {
+		return s.err
+	}
+	return s.source.Err()
+}
+
+func (s *openAIInboundStream) Close() error {
+	return s.source.Close()
+}
+
+// ensureStreamFinishReason synthesizes finish_reason for stream chunks when the
+// upstream provider omits it. hasSeenToolCalls tracks whether prior chunks
+// contained tool calls, used to infer finish_reason for terminal usage-only chunks.
+//
+// Two cases:
+//  1. A chunk with a new tool call (delta.tool_calls[*].id != "") but no
+//     finish_reason → set "tool_calls". Only the first chunk of each tool call
+//     receives finish_reason; subsequent argument-only chunks leave it nil,
+//     matching the OpenAI streaming pattern where intermediate chunks have
+//     finish_reason=null.
+//  2. A terminal usage-only chunk (empty choices + usage) with no finish_reason
+//     in any choice → inject a synthetic choice. If prior chunks contained tool
+//     calls, finish_reason is "tool_calls"; otherwise "stop". This follows the
+//     OpenAI SSE pattern where the final chunk carries both finish_reason and
+//     usage metadata.
+func ensureStreamFinishReason(resp *llm.Response, hasSeenToolCalls *bool) {
+	hasFinishReason := false
+
+	for i := range resp.Choices {
+		c := &resp.Choices[i]
+		if c.FinishReason != nil && *c.FinishReason != "" {
+			hasFinishReason = true
+			continue
+		}
+		if c.Delta == nil || len(c.Delta.ToolCalls) == 0 {
+			continue
+		}
+		// Only synthesize finish_reason on the first chunk of a tool call
+		// (id != ""), not on subsequent argument-only chunks.
+		hasNewToolCall := false
+		for _, tc := range c.Delta.ToolCalls {
+			if tc.ID != "" {
+				hasNewToolCall = true
+				break
+			}
+		}
+		if hasNewToolCall {
+			c.FinishReason = lo.ToPtr("tool_calls")
+			hasFinishReason = true
+		}
+		*hasSeenToolCalls = true
+	}
+
+	// Terminal usage-only chunk: inject a synthetic choice so the client
+	// sees a finish_reason before [DONE]. If we've seen tool calls in prior
+	// chunks but none got a synthesized finish_reason (provider never sets
+	// it), the correct reason is "tool_calls" rather than "stop".
+	if !hasFinishReason && len(resp.Choices) == 0 && resp.Usage != nil {
+		reason := "stop"
+		if *hasSeenToolCalls {
+			reason = "tool_calls"
+		}
+		resp.Choices = append(resp.Choices, llm.Choice{
+			Index:        0,
+			Delta:        &llm.Message{},
+			FinishReason: lo.ToPtr(reason),
+		})
+	}
+}
